{
  "name": "contracts",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "watcher": "npx ts-node scripts/watcher.ts",
    "payout": "npx ts-node scripts/run-payout.ts",
    "generate-client": "algokit generate client artifacts/ --language typescript  --output clients/{contract_name}Client.ts",
    "compile-contract": "tealscript *.algo.ts artifacts",
    "generate-components": "algokit-generate-component artifacts/Zyura.arc32.json artifacts/components",
    "build": "npm run compile-contract && npm run generate-client",
    "deploy:zyura": "npm run build && npx ts-node scripts/deploy-and-create-products.ts",
    "test": "npm run build && jest",
    "test:only": "jest",
    "lint": "eslint . --ext .ts",
    "fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^7.1.0",
    "algosdk": "^2.11.0",
    "bip39": "^3.1.0",
    "dotenv": "^17.4.2",
    "ed25519-hd-key": "^1.3.0"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-client-generator": "^4.0.9",
    "@algorandfoundation/tealscript": "latest",
    "@jest/globals": "^29.7.0",
    "@joe-p/algokit-generate-component": "^0.2.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "6.0.3"
  }
}
