#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "pre-push: running quality gates..."

run_frontend_checks=false
run_contract_checks=false

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "${local_sha:-}" ]; then
    continue
  fi

  if echo "${remote_sha:-}" | grep -Eq '^0+$'; then
    run_frontend_checks=true
    run_contract_checks=true
    continue
  fi

  for changed_file in $(git diff --name-only "$remote_sha" "$local_sha"); do
    case "$changed_file" in
      frontend/*|.github/*)
        run_frontend_checks=true
        ;;
      contracts/*|.github/*)
        run_contract_checks=true
        ;;
    esac
  done
done

if [ "$run_frontend_checks" = false ] && [ "$run_contract_checks" = false ]; then
  run_frontend_checks=true
  run_contract_checks=true
fi

max_jobs="$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 4)"
case "$max_jobs" in
  ''|*[!0-9]*)
    max_jobs=4
    ;;
esac

parallel_commands_file="$(mktemp)"
trap 'rm -f "$parallel_commands_file"' EXIT INT TERM

if [ "$run_frontend_checks" = true ]; then
  cat >>"$parallel_commands_file" <<'EOF'
pnpm -C frontend format:check
pnpm -C frontend lint
EOF
fi

if [ "$run_contract_checks" = true ]; then
  cat >>"$parallel_commands_file" <<'EOF'
pnpm -C contracts lint
pnpm -C contracts compile-contract
EOF
fi

echo "pre-push: running checks with up to ${max_jobs} parallel workers"
if ! xargs -I{} -P "$max_jobs" sh -c 'echo ">>> {}"; {}' <"$parallel_commands_file"; then
  echo "pre-push: one or more checks failed."
  exit 1
fi

if [ "$run_frontend_checks" = true ]; then
  echo "pre-push: running frontend typecheck (serial)"
  pnpm -C frontend typecheck

  echo "pre-push: running frontend build (serial)"
  pnpm -C frontend build
fi

echo "pre-push: all checks passed."
